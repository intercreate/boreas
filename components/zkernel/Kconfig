menu "Boreas Kernel (zkernel)"

    config ZKERNEL_MUTEX_DEBUG
        bool "Enable mutex lock-ordering assertions"
        default n
        help
            When enabled, each mutex is assigned a numeric lock order.
            Acquiring mutexes out of order triggers an assertion failure.
            Adds ~4 bytes per mutex and a small runtime check on lock.

    config ZKERNEL_MUTEX_HOLD_WARNING_MS
        int "Mutex hold-time warning threshold (ms)"
        default 0
        depends on ZKERNEL_MUTEX_DEBUG
        help
            Log a warning if a mutex is held longer than this many
            milliseconds. Set to 0 to disable hold-time warnings.

    config ZKERNEL_THREAD_ANALYZER
        bool "Enable thread analyzer"
        default n
        help
            Enables runtime thread stack and CPU usage analysis.
            Adds a CLI command and periodic reporting capability.

    config ZKERNEL_SYS_INIT
        bool "Enable SYS_INIT ordered initialization framework"
        default y
        help
            Enables the SYS_INIT macro for declarative, priority-ordered
            component initialization and shutdown.

    config ZKERNEL_SYS_INIT_MAX_ENTRIES
        int "Maximum number of SYS_INIT entries"
        default 32
        depends on ZKERNEL_SYS_INIT
        help
            Maximum number of components that can register via SYS_INIT.

    config SYSTEM_WORKQUEUE_PRIORITY
        int "System workqueue thread priority"
        default 5
        help
            FreeRTOS task priority for the auto-initialized system
            workqueue (k_sys_work_q). Higher number = higher priority.
            Mirrors upstream Zephyr's CONFIG_SYSTEM_WORKQUEUE_PRIORITY.

    config SYSTEM_WORKQUEUE_STACK_SIZE
        int "System workqueue thread stack size (bytes)"
        default 4096
        help
            Stack size for the auto-initialized system workqueue
            (k_sys_work_q) worker thread. Mirrors upstream Zephyr's
            CONFIG_SYSTEM_WORKQUEUE_STACK_SIZE.

    config SYSTEM_WORKQUEUE_NO_YIELD
        bool "System workqueue: do not yield between work items"
        default n
        help
            When enabled, the system workqueue worker does not yield
            between handler invocations. Lets a high-priority worker
            drain its queue without preemption, at the cost of
            responsiveness for equal-or-lower-priority work. Mirrors
            upstream Zephyr's CONFIG_SYSTEM_WORKQUEUE_NO_YIELD.

    config K_TIMER_DISPATCH_ISR
        bool "Dispatch k_timer callbacks in ISR context"
        depends on !IDF_TARGET_LINUX
        default y
        select ESP_TIMER_SUPPORTS_ISR_DISPATCH_METHOD
        help
            When enabled, k_timer expiry callbacks run in true ISR context
            (ESP_TIMER_ISR dispatch), matching upstream Zephyr's contract.
            Callbacks must be IRAM_ATTR and must not call blocking APIs.

            When disabled, callbacks run on the ESP_TIMER_TASK (a normal
            FreeRTOS task). Blocking calls are permitted but the behavior
            diverges from upstream Zephyr.

            Unavailable on the linux target: esp_timer is headers-only
            there, and the k_timer linux backend dispatches from a
            dedicated FreeRTOS task (task-context semantics).

    config K_TIMER_LINUX_DISPATCHER_PRIORITY
        int "k_timer linux dispatcher task priority"
        depends on IDF_TARGET_LINUX
        default 20
        help
            FreeRTOS task priority for the k_timer expiry dispatcher on
            the linux target. Should be higher than any task that relies
            on timely k_timer / k_work_delayable expiry, mirroring the
            high-priority esp_timer task on hardware.

    config K_TIMER_LINUX_DISPATCHER_STACK_SIZE
        int "k_timer linux dispatcher task stack size (bytes)"
        depends on IDF_TARGET_LINUX
        default 8192
        help
            Stack size for the k_timer expiry dispatcher task on the
            linux target. Expiry callbacks run on this stack. Mirrors
            the SYSTEM_WORKQUEUE_STACK_SIZE pattern.

    config ZKERNEL_FATAL_CAPTURE
        bool "Capture fatal error context to NVS"
        default n
        help
            On fatal error or assertion failure, save task name, backtrace,
            and heap state to NVS. Printed on next boot.

endmenu
