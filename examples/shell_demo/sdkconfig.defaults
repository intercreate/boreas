# Shell demo defaults
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_MAIN_TASK_STACK_SIZE=4096

# Enable shell
CONFIG_ZSHELL=y
CONFIG_ZSHELL_CMD_KERNEL=y
CONFIG_ZSHELL_CMD_LOG=y
CONFIG_ZSHELL_CMD_THREAD=y
CONFIG_ZSHELL_ECHO=y
CONFIG_ZSHELL_HISTORY=y
CONFIG_ZSHELL_VT100=y
CONFIG_ZSHELL_TAB_COMPLETION=y

# Enable zsys features for shell builtins
CONFIG_ZSYS_LOG_MODULE=y
CONFIG_ZSYS_RETRY=y

# SYS_INIT
CONFIG_ZKERNEL_SYS_INIT=y
